{
  "name": "rdxmin",
  "version": "1.2.2",
  "description": "Maximum-efficiency dev mode for Claude Code. Zero-fluff prose + YAGNI-first code decisions. One plugin that does both.",
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "productivity",
    "yagni",
    "minimal"
  ],
  "license": "MIT",
  "author": {
    "name": "Jay Pokale",
    "url": "https://github.com/JayPokale"
  },
  "contributors": [
    {
      "name": "Claude (Anthropic)",
      "url": "https://claude.com/claude-code"
    },
    {
      "name": "Antigravity (Google)",
      "url": "https://antigravity.google"
    },
    {
      "name": "Codex (OpenAI)",
      "url": "https://openai.com/codex/"
    }
  ],
  "homepage": "https://rdx.jaypokale.me",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JayPokale/RDXmin.git"
  },
  "bugs": {
    "url": "https://github.com/JayPokale/RDXmin/issues"
  },
  "bin": {
    "rdxmin": "bin/install.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test tests/*.js",
    "build:rules": "node scripts/build-rules.js",
    "check:rules": "node scripts/build-rules.js --check",
    "build:chart": "node scripts/build-chart.js",
    "check:chart": "node scripts/build-chart.js --check",
    "bench": "bash benchmarks/run-live.sh"
  },
  "files": [
    "bin/",
    "hooks/",
    "skills/",
    "commands/",
    "rules/",
    "AGENTS.md",
    ".cursor/",
    ".windsurf/",
    ".clinerules/",
    ".kiro/",
    ".github/copilot-instructions.md",
    ".claude-plugin/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
